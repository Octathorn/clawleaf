## App (SSR + client)
## WhatsApp float: digits only with country code (e.g. 923379611572). Falls back if unset.
# VITE_WHATSAPP_NUMBER=923379611572

VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-04-14
VITE_SANITY_USE_CDN=true

## SSR server (optional; VITE_ vars also work)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-04-14
SANITY_USE_CDN=true

## Sanity Studio (inside ./sanity)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

